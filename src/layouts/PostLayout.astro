---
import PageLayout from './PageLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  image?: string;
}

const { title, description, pubDate, updatedDate, tags = [], image } = Astro.props;

const dateFormatter = new Intl.DateTimeFormat('pt-BR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<PageLayout title={title} description={description} image={image} type="article" publishedDate={pubDate}>
  <article>
    <div class="mb-8">
      <a href="/blog" class="text-muted hover:text-accent text-sm font-mono transition-colors">
        &larr; Voltar ao blog
      </a>
    </div>

    <header class="mb-10">
      <h1 class="text-3xl md:text-4xl font-bold text-headings mb-4">{title}</h1>
      <div class="flex flex-wrap items-center gap-3 text-sm text-muted font-mono">
        <time datetime={pubDate.toISOString()}>
          {dateFormatter.format(pubDate)}
        </time>
        {updatedDate && (
          <span>
            · Atualizado em <time datetime={updatedDate.toISOString()}>
              {dateFormatter.format(updatedDate)}
            </time>
          </span>
        )}
      </div>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag) => (
            <span class="text-xs font-mono px-2 py-1 rounded bg-surface text-accent border border-border">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <div class="prose max-w-none">
      <slot />
    </div>
  </article>
</PageLayout>
