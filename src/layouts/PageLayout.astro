---
import BaseLayout from './BaseLayout.astro';
import CommandPalette from '@/components/CommandPalette.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
}

const { title, description, image, type, publishedDate } = Astro.props;
---

<BaseLayout title={title} description={description} image={image} type={type} publishedDate={publishedDate}>
  <CommandPalette />
  <main class="flex-1 max-w-5xl mx-auto px-4 pt-20 pb-12 w-full">
    <slot />
  </main>
  <Footer />
</BaseLayout>
