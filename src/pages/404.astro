---
import PageLayout from '@/layouts/PageLayout.astro';
---

<PageLayout title="404" description="Página não encontrada.">
  <div class="flex flex-col items-center justify-center py-20 text-center">
    <h1 class="text-6xl font-mono font-bold text-accent mb-4">404</h1>
    <p class="text-xl text-muted mb-8">Página não encontrada.</p>
    <a
      href="/"
      class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent text-bg font-mono text-sm font-medium rounded hover:bg-accent/90 transition-colors"
    >
      &larr; Voltar ao início
    </a>
  </div>
</PageLayout>
