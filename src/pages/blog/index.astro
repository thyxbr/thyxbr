---
import PageLayout from '@/layouts/PageLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Agrupar por mês/ano
const monthFormatter = new Intl.DateTimeFormat('pt-BR', { year: 'numeric', month: 'long' });
const dateGroups = new Map<string, { label: string; count: number }>();
posts.forEach((post) => {
  const key = `${post.data.pubDate.getFullYear()}-${String(post.data.pubDate.getMonth() + 1).padStart(2, '0')}`;
  if (!dateGroups.has(key)) {
    const label = monthFormatter.format(post.data.pubDate);
    dateGroups.set(key, { label: label.charAt(0).toUpperCase() + label.slice(1), count: 0 });
  }
  dateGroups.get(key)!.count++;
});

// Extrair tags únicas
const tagCounts = new Map<string, number>();
posts.forEach((post) => {
  post.data.tags.forEach((tag) => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});
const allTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<PageLayout title="Blog" description="Artigos sobre desenvolvimento de software, tecnologias e experiências.">
  <div>
    <h1 class="text-3xl md:text-4xl font-bold text-headings mb-2">
      Blog<span class="text-accent">.</span>
    </h1>
    <p class="text-muted mb-8">
      Artigos sobre desenvolvimento, tecnologias e coisas que aprendo pelo caminho.
    </p>

    {posts.length > 0 ? (
      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Cards (esquerda) -->
        <div class="flex-1 min-w-0">
          <div class="grid gap-4" id="cards-container">
            {posts.map((post) => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
                slug={post.slug}
              />
            ))}
          </div>

          <p id="no-results" class="text-muted font-mono text-sm text-center py-8 hidden">
            Nenhum artigo encontrado com esses filtros.
          </p>

          <p id="filter-count" class="text-xs font-mono text-muted mt-4"></p>
        </div>

        <!-- Filtros (sidebar direita) -->
        <aside class="lg:w-56 shrink-0 order-first lg:order-last">
          <div class="lg:sticky lg:top-20 space-y-6">
            <!-- Filtro por data -->
            <div>
              <h3 class="text-xs font-mono text-muted uppercase tracking-wider mb-3">Por data</h3>
              <div class="flex flex-col gap-1" id="date-filters">
                <button
                  data-date="all"
                  class="date-btn active-filter text-left px-2 py-1 rounded text-xs font-mono text-text hover:text-accent transition-colors"
                >
                  Todos ({posts.length})
                </button>
                {[...dateGroups.entries()].map(([key, { label, count }]) => (
                  <button
                    data-date={key}
                    class="date-btn text-left px-2 py-1 rounded text-xs font-mono text-muted hover:text-accent transition-colors"
                  >
                    {label} ({count})
                  </button>
                ))}
              </div>
            </div>

            <!-- Filtro por tags -->
            {allTags.length > 0 && (
              <div>
                <div class="flex items-center justify-between mb-3">
                  <h3 class="text-xs font-mono text-muted uppercase tracking-wider">Por tags</h3>
                  <button id="clear-tags" class="text-xs font-mono text-muted hover:text-accent transition-colors hidden">Limpar</button>
                </div>
                <div class="flex flex-wrap gap-1.5" id="tag-filters">
                  {allTags.map(([tag, count]) => (
                    <button
                      data-tag={tag}
                      class="tag-btn px-2 py-0.5 rounded text-xs font-mono border border-border text-muted hover:border-accent2 hover:text-accent2 transition-colors"
                    >
                      #{tag} ({count})
                    </button>
                  ))}
                </div>
              </div>
            )}
          </div>
        </aside>
      </div>
    ) : (
      <p class="text-muted font-mono text-sm">Nenhum artigo publicado ainda.</p>
    )}
  </div>
</PageLayout>

<script>
  const dateFilters = document.getElementById('date-filters');
  const tagFilters = document.getElementById('tag-filters');
  const clearTags = document.getElementById('clear-tags');
  const filterCount = document.getElementById('filter-count');
  const noResults = document.getElementById('no-results');
  const cards = document.querySelectorAll<HTMLElement>('.filter-item');

  let activeDate = 'all';
  let activeTags = new Set<string>();

  function applyFilters() {
    let visible = 0;
    cards.forEach((card) => {
      const cardDate = card.dataset.date || '';
      const cardTags = card.dataset.tags ? card.dataset.tags.split(',') : [];
      const dateMatch = activeDate === 'all' || cardDate === activeDate;
      const tagMatch = activeTags.size === 0 || cardTags.some((t) => activeTags.has(t));
      const show = dateMatch && tagMatch;
      card.classList.toggle('hidden', !show);
      if (show) visible++;
    });
    if (filterCount) {
      const total = cards.length;
      filterCount.textContent = (activeDate === 'all' && activeTags.size === 0)
        ? '' : `Exibindo ${visible} de ${total} artigos`;
    }
    if (noResults) noResults.classList.toggle('hidden', visible > 0);
  }

  dateFilters?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.date-btn') as HTMLElement;
    if (!btn) return;
    activeDate = btn.dataset.date || 'all';
    dateFilters.querySelectorAll('.date-btn').forEach((b) => {
      b.classList.remove('active-filter', 'text-text');
      b.classList.add('text-muted');
    });
    btn.classList.add('active-filter', 'text-text');
    btn.classList.remove('text-muted');
    applyFilters();
  });

  tagFilters?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.tag-btn') as HTMLElement;
    if (!btn) return;
    const tag = btn.dataset.tag!;
    if (activeTags.has(tag)) {
      activeTags.delete(tag);
      btn.classList.remove('border-accent2', 'text-accent2');
      btn.classList.add('text-muted');
    } else {
      activeTags.add(tag);
      btn.classList.add('border-accent2', 'text-accent2');
      btn.classList.remove('text-muted');
    }
    clearTags?.classList.toggle('hidden', activeTags.size === 0);
    applyFilters();
  });

  clearTags?.addEventListener('click', () => {
    activeTags.clear();
    tagFilters?.querySelectorAll('.tag-btn').forEach((b) => {
      b.classList.remove('border-accent2', 'text-accent2');
      b.classList.add('text-muted');
    });
    clearTags.classList.add('hidden');
    applyFilters();
  });
</script>
