---
import PageLayout from '@/layouts/PageLayout.astro';
import ExperienceItem from '@/components/ExperienceItem.astro';
import SkillBadge from '@/components/SkillBadge.astro';
import { experiences, skills, education } from '@/data/resume';
---

<PageLayout title="Currículo" description="Experiência profissional, habilidades técnicas e formação de Henrique.">
  <div class="max-w-2xl">
    <h1 class="text-3xl md:text-4xl font-bold text-headings mb-12">
      Currículo<span class="text-accent">.</span>
    </h1>

    <!-- Experiência -->
    <section class="mb-12">
      <h2 class="text-xl font-bold text-headings mb-6 flex items-center gap-2">
        <span class="text-accent font-mono">#</span> Experiência
      </h2>
      <div>
        {experiences.map((exp) => (
          <ExperienceItem
            title={exp.title}
            company={exp.company}
            period={exp.period}
            description={exp.description}
          />
        ))}
      </div>
    </section>

    <!-- Habilidades -->
    <section class="mb-12">
      <h2 class="text-xl font-bold text-headings mb-6 flex items-center gap-2">
        <span class="text-accent font-mono">#</span> Habilidades
      </h2>
      <div class="flex flex-wrap gap-2">
        {skills.map((skill) => (
          <SkillBadge name={skill} />
        ))}
      </div>
    </section>

    <!-- Educação -->
    <section>
      <h2 class="text-xl font-bold text-headings mb-6 flex items-center gap-2">
        <span class="text-accent font-mono">#</span> Educação
      </h2>
      <div>
        {education.map((edu) => (
          <div class="p-4 rounded-lg border border-border bg-surface/50">
            <h3 class="text-headings font-bold">{edu.title}</h3>
            <p class="text-accent font-mono text-sm">{edu.institution}</p>
            <p class="text-muted font-mono text-xs">{edu.period}</p>
          </div>
        ))}
      </div>
    </section>
  </div>
</PageLayout>
