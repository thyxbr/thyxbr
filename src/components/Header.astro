---
const pathname = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/sobre', label: 'Sobre' },
  { href: '/curriculo', label: 'Currículo' },
  { href: '/blog', label: 'Blog' },
  { href: '/links', label: 'Links' },
];
---

<header class="border-b border-border bg-bg/80 backdrop-blur-sm sticky top-0 z-50">
  <nav class="max-w-4xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="font-mono text-lg font-bold text-accent hover:text-accent/80 transition-colors">
      &gt; henrique<span class="cursor-blink text-accent2">_</span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-6">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'font-mono text-sm transition-colors',
              pathname === href || (href !== '/' && pathname.startsWith(href))
                ? 'text-accent'
                : 'text-muted hover:text-text',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden text-muted hover:text-text transition-colors"
      aria-label="Menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border">
    <ul class="max-w-4xl mx-auto px-4 py-4 flex flex-col gap-3">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'font-mono text-sm block py-1 transition-colors',
              pathname === href || (href !== '/' && pathname.startsWith(href))
                ? 'text-accent'
                : 'text-muted hover:text-text',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
