---
interface Props {
  title: string;
  company: string;
  period: string;
  description: string;
}

const { title, company, period, description } = Astro.props;
---

<div class="relative pl-6 pb-8 border-l border-border last:pb-0 group">
  <div class="absolute left-0 top-1 w-2.5 h-2.5 -translate-x-[5.5px] rounded-full bg-border group-hover:bg-accent transition-colors"></div>
  <div class="space-y-1">
    <h3 class="text-headings font-bold">{title}</h3>
    <p class="text-accent font-mono text-sm">{company}</p>
    <p class="text-muted font-mono text-xs">{period}</p>
    <p class="text-text text-sm leading-relaxed pt-1">{description}</p>
  </div>
</div>
