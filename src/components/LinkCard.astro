---
interface Props {
  title: string;
  url: string;
  description: string;
  pubDate: Date;
  source?: string;
  tags?: string[];
}

const { title, url, description, pubDate, source, tags = [] } = Astro.props;

const dateFormatter = new Intl.DateTimeFormat('pt-BR', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const dateKey = `${pubDate.getFullYear()}-${String(pubDate.getMonth() + 1).padStart(2, '0')}`;
---

<a href={url} target="_blank" rel="noopener noreferrer" class="filter-item group flex items-start gap-4 p-4 rounded-lg border border-border bg-surface/50 hover:border-accent/50 transition-all" data-date={dateKey} data-tags={tags.join(',')}>
  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-2 mb-1">
      <time class="text-xs font-mono text-muted" datetime={pubDate.toISOString()}>
        {dateFormatter.format(pubDate)}
      </time>
      {source && (
        <span class="text-xs font-mono px-1.5 py-0.5 rounded bg-accent2/10 text-accent2">
          {source}
        </span>
      )}
    </div>
    <h3 class="text-sm font-bold text-headings group-hover:text-accent transition-colors mb-1">
      {title}
    </h3>
    <p class="text-muted text-xs leading-relaxed line-clamp-2">
      {description}
    </p>
  </div>
  <svg class="w-4 h-4 text-muted group-hover:text-accent transition-colors mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
  </svg>
</a>
